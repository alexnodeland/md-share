{
  "name": "md-share",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Render, share, and export Markdown — no server required.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexnodeland/md-share.git"
  },
  "homepage": "https://alexnodeland.github.io/md-share/",
  "bugs": {
    "url": "https://github.com/alexnodeland/md-share/issues"
  },
  "author": "Alex Nodeland (https://alexnodeland.github.io/alexnodeland/)",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome check --error-on-warnings .",
    "verify": "npm run check:ci && npm run typecheck && npm run test",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && npx tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@viz-js/viz": "^3.26.0",
    "abcjs": "^6.6.2",
    "chess.js": "^1.4.0",
    "docx": "^9.6.1",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "katex": "^0.16.45",
    "lz-string": "^1.5.0",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.1",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "mermaid": "^11.14.0",
    "qrcode-generator": "^2.0.4",
    "turndown": "^7.2.4",
    "vega-embed": "^7.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "happy-dom": "^20.9.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
